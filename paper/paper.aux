\citation{temme2017error,li2017efficient}
\@writefile{lof}{\contentsline {figure}{\numberline {1}{\ignorespaces Log-log convergence: RMSE vs.\ total oracle queries. Classical MC (red) follows $O(1/\sqrt  {N})$. Grover-amplified QAE (blue) converges faster, with each point annotated by its $k$ value. Reference slopes for $O(1/\sqrt  {N})$ and $O(1/N)$ are shown as dashed lines.}}{5}{figure.caption.7}\protected@file@percent }

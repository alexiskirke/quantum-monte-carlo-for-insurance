\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces QAE RMSE under increasing NISQ noise at $k = 3$ Grover iterations. The noiseless baseline (RMSE = \$32) degrades to $\sim $\$2{,}100 under even low noise --- a $66\times $ increase, driven by the $\sim $700-gate circuit depth.}}{6}{figure.caption.9}\protected@file@percent }
\newlabel{fig:exp2}{{2}{6}{QAE RMSE under increasing NISQ noise at $k = 3$ Grover iterations. The noiseless baseline (RMSE = \$32) degrades to $\sim $\$2{,}100 under even low noise --- a $66\times $ increase, driven by the $\sim $700-gate circuit depth}{figure.caption.9}{}}
\@writefile{lot}{\contentsline {table}{\numberline {3}{\ignorespaces Experiment 3: excess-loss estimation at tail percentiles ($n_{\text  {reps}} = 30$). Classical MC uses 500 samples. Quantum Grover uses $k_{\text  {use}} = \min (k_{\max }, 6)$ iterations with shots budget-matched to 8{,}192 total oracle queries.}}{6}{table.caption.10}\protected@file@percent }
\newlabel{tab:exp3}{{3}{6}{Experiment 3: excess-loss estimation at tail percentiles ($n_{\text {reps}} = 30$). Classical MC uses 500 samples. Quantum Grover uses $k_{\text {use}} = \min (k_{\max }, 6)$ iterations with shots budget-matched to 8{,}192 total oracle queries}{table.caption.10}{}}
\citation{zoufal2019quantum}
\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces Experiment 3: excess-loss RMSE (left) and normalised query inefficiency (right) at three tail percentiles. The quantum advantage grows with tail depth because deeper tails produce smaller $P(|1\rangle )$, enabling more Grover iterations.}}{7}{figure.caption.11}\protected@file@percent }
\newlabel{fig:exp3}{{3}{7}{Experiment 3: excess-loss RMSE (left) and normalised query inefficiency (right) at three tail percentiles. The quantum advantage grows with tail depth because deeper tails produce smaller $P(|1\rangle )$, enabling more Grover iterations}{figure.caption.11}{}}
